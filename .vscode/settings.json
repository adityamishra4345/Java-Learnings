{
    "java.debug.settings.onBuildFailureProceed": true,
    
    "files.exclude": {
      "**/*.class": true
    },
    
    "Quick Print": {
        "prefix": "pr",
        "body": [
            "System.out.println($1);"
        ],
        "description": "Shortcut for System.out.println"
    },

    "Basic Java Boilerplate": {
        "prefix": "boiler",
        "body": [
            "public class ${1:Main} {",
            "\tpublic static void main(String[] args) {",
            "\t\t$2",
            "\t}",
            "}"
        ],
        "description": "Standard Java class and main method boilerplate"
    },

    "Main Method Only": {
        "prefix": "main",
        "body": [
            "public static void main(String[] args) {",
            "\t$1",
            "}"
        ],
        "description": "Generates just the main method"
    },

    "Scanner for User Input": {
        "prefix": "scan",
        "body": [
            "java.util.Scanner sc = new java.util.Scanner(System.in);",
            "System.out.print(\"Enter ${1:value}: \");",
            "${2:int} ${3:input} = sc.next${4:Int}();",
            "$0"
        ],
        "description": "Sets up a Scanner and prompts for input"
    },

    "Standard For Loop": {
        "prefix": "fori",
        "body": [
            "for (int ${1:i} = 0; ${1:i} < ${2:10}; ${1:i}++) {",
            "\t$0",
            "}"
        ],
        "description": "Standard counting for-loop"
    },

    "Enhanced For-Each Loop": {
        "prefix": "fore",
        "body": [
            "for (${1:String} ${2:item} : ${3:collection}) {",
            "\t$0",
            "}"
        ],
        "description": "For-each loop for arrays and lists"
    },

    "Create ArrayList": {
        "prefix": "list",
        "body": [
            "java.util.List<${1:Integer}> ${2:list} = new java.util.ArrayList<>();",
            "$0"
        ],
        "description": "Creates a new ArrayList"
    }


}